# --- Claude (Anthropic) API ---
# Crie em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-SUBSTITUA-AQUI

# --- Google Sheets ---
# ID da planilha (está na URL do Google Sheets)
SPREADSHEET_ID=1AQFD-GVAFxwqscYkDuC4q4PMa8C93v_3zCb-uUbBEOA

# Credenciais da conta de serviço (Google Cloud)
# Cole o conteúdo JSON inteiro como uma string (sem quebras de linha)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# --- Telegram Bot ---
# Token gerado pelo BotFather
TELEGRAM_BOT_TOKEN=123456789:AAF-SUBSTITUA-AQUI

# Chat ID do grupo onde os alertas serão enviados
# (o grupo "Gastos - M&P" — veja README para descobrir o ID)
